# Copy this file to secrets.env and fill in your values.
# secrets.env is listed in .gitignore — do NOT commit it.

# Weather Underground API key
WU_API_KEY=your_wunderground_api_key_here

# Your personal weather station ID (temperature, humidity, pressure source)
MY_PWS_ID=KCTSTAMF61

# Comma-separated list of nearby PWS IDs (wind data source)
NEARBY_PWS_IDS=KCTSTAMF161,KCTSTAMF182,KCTSTAMF152,KCTSTAMF158,KCTNEWCA41,KCTSTAMF117
